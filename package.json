{
  "name": "login-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "node -e \"const fs=require('fs');const path=require('path');const rm=(p)=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}};rm('.next/dev/lock');rm('.next/dev/cache');\"",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:backup": "node backup-db.js --verify",
    "db:push": "prisma db push",
    "db:restore": "node restore-db.js",
    "db:seed": "npx prisma db seed",
    "db:seed-livestock": "node prisma/seed-livestock.js",
    "db:seed-utilities": "node prisma/seed-utilities.js",
    "db:super-admin": "node scripts/ensure-super-admin.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
